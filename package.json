{
  "name": "millas",
  "version": "0.2.12-beta-1",
  "description": "A modern batteries-included Node.js framework",
  "main": "src/index.js",
  "bin": {
    "millas": "./bin/millas.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node bin/millas.js serve",
    "test": "node --test",
    "audit:check": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "security:check": "npm run audit:check"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "chalk": "5.3.0",
    "commander": "11.1.0"
  },
  "devDependencies": {
    "nodemon": "3.0.3"
  },
  "peerDependencies": {
    "express": ">=4.18.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    }
  },
  "keywords": [
    "framework",
    "nodejs",
    "web",
    "millas"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/millas/millas"
  },
  "files": [
    "bin/",
    "config/",
    "src/",
    "README.md"
  ]
}