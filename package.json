{
  "name": "millas",
  "version": "0.2.28",
  "description": "A modern batteries-included backend framework for Node.js — built on Express, inspired by Laravel, Django, and FastAPI",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./core/*": "./src/core/*.js",
    "./middleware/*": "./src/middleware/*.js",
    "./facades/*": "./src/facades/*.js",
    "./console": "./src/console/index.js",
    "./console/*": "./src/console/*.js"
  },
  "bin": {
    "millas": "./bin/millas.js"
  },
  "scripts": {
    "test": "echo \"Run phase-specific tests in tests/\""
  },
  "keywords": [
    "framework",
    "express",
    "orm",
    "cli",
    "auth",
    "queue",
    "cache",
    "admin",
    "mail",
    "events",
    "laravel",
    "django",
    "fastapi",
    "millas"
  ],
  "author": "Millas Framework",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "3.0.2",
    "chalk": "4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^11.0.0",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.0.0",
    "inquirer": "8.2.6",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "nodemailer": "^6.9.0",
    "nunjucks": "^3.2.4",
    "ora": "5.4.1",
    "sqlite3": "5.1.6",
    "node-cron": "^4.2.1"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "pg": "^8.20.0",
    "multer": "^1.4.5 || ^2.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    },
    "multer": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    }
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/millas-framework/millas"
  },
  "homepage": "https://millas.dev",
  "bugs": {
    "url": "https://github.com/millas-framework/millas/issues"
  }
}
