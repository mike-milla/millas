<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="{{ csrfToken }}">
  <title>{% block title %}{{ pageTitle }}{% endblock %} — {{ adminTitle }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ adminPrefix }}/static/admin.css?v=21">
  <link rel="stylesheet" href="{{ adminPrefix }}/static/json-editor.css?v=4">
  <link rel="stylesheet" href="{{ adminPrefix }}/static/date-picker.css?v=3">
  <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
  {% block head %}{% endblock %}
</head>
<body>

  {# ══════════════════════════════════════
     SVG ICON DEFINITIONS (hidden sprite)
     ══════════════════════════════════════ #}
  {% include "partials/icons.njk" %}

  {# ══════════════════════════════════════
     SIDEBAR
     ══════════════════════════════════════ #}
  <nav id="sidebar">
    <div class="sidebar-brand">
      <div class="brand-logo">
        <span class="icon icon-18">{% include "icons/database.svg" ignore missing %}<svg viewBox="0 0 24 24"><use href="#ic-database"/></svg></span>
      </div>
      <div class="brand-text">
        <div class="brand-name">{{ adminTitle }}</div>
        <div class="brand-sub">Admin Panel</div>
      </div>
    </div>

    <div class="nav-section">
      <div class="nav-label">Overview</div>
      <a href="{{ adminPrefix }}/" class="nav-item {% if activePage == 'dashboard' %}active{% endif %}">
        <span class="nav-icon icon icon-16">
          <svg viewBox="0 0 24 24"><use href="#ic-grid"/></svg>
        </span>
        Dashboard
      </a>
    </div>

    {% if resources | length %}
    <div class="nav-section">
      <div class="nav-label">Resources</div>
      {% for resource in resources %}
      {% if resource.category != 'auth' %}
      <a href="{{ adminPrefix }}/{{ resource.slug }}" class="nav-item {% if activeResource == resource.slug %}active{% endif %}">
        <span class="nav-icon icon icon-16">
          <svg viewBox="0 0 24 24"><use href="#ic-{{ resource.icon or 'table' }}"/></svg>
        </span>
        {{ resource.label }}
      </a>
      {% endif %}
      {% endfor %}
    </div>

    {% set hasAuth = false %}
    {% for resource in resources %}{% if resource.category == 'auth' %}{% set hasAuth = true %}{% endif %}{% endfor %}
    {% if hasAuth %}
    <div class="nav-section">
      <div class="nav-label">Auth</div>
      {% for resource in resources %}
      {% if resource.category == 'auth' %}
      <a href="{{ adminPrefix }}/{{ resource.slug }}" class="nav-item {% if activeResource == resource.slug %}active{% endif %}">
        <span class="nav-icon icon icon-16">
          <svg viewBox="0 0 24 24"><use href="#ic-{{ resource.icon or 'user' }}"/></svg>
        </span>
        {{ resource.label }}
      </a>
      {% endif %}
      {% endfor %}
    </div>
    {% endif %}
    {% endif %}

    <div class="sidebar-footer">
      {% if authEnabled and adminUser %}
      <div class="user-row">
        <div class="user-avatar">{{ (adminUser.name or adminUser.email or 'A')[0] | upper }}</div>
        <div class="user-info">
          <div class="user-name truncate">{{ adminUser.name or adminUser.email }}</div>
          {% if adminUser.name %}<div class="user-email truncate">{{ adminUser.email }}</div>{% endif %}
        </div>
        <a href="{{ adminPrefix }}/logout" class="logout-btn" title="Sign out">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </a>
      </div>
      {% endif %}
      <div class="sidebar-version flex items-center gap-1" style="{% if authEnabled and adminUser %}margin-top:10px;padding-top:10px;border-top:1px solid var(--border-soft);{% endif %}">
        <span class="icon icon-12" style="color:var(--text-xmuted)"><svg viewBox="0 0 24 24"><use href="#ic-activity"/></svg></span>
        Millas v0.1.2
      </div>
    </div>
  </nav>

  {# ══════════════════════════════════════
     MAIN
     ══════════════════════════════════════ #}
  <div id="main">
    <header id="topbar">
      <span class="topbar-title">{% block topbar_title %}{{ pageTitle }}{% endblock %}</span>

      {# ── Global search ── #}
      <form action="{{ adminPrefix }}/search" method="GET" id="global-search-form" style="flex:1;max-width:280px;margin:0 16px">
        <div class="search-wrap">
          <span class="search-icon-inner">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </span>
          <input
            type="text"
            name="q"
            id="global-search-input"
            placeholder="Search everything… (/)"
            class="form-control search-input"
            value="{% if query is defined %}{{ query }}{% endif %}"
            autocomplete="off"
            style="width:100%;font-size:13px">
        </div>
      </form>

      <div class="topbar-actions">
        {% block topbar_actions %}{% endblock %}
      </div>
    </header>

    <div id="content">
      {% if flash.success %}
        <div class="alert alert-success" id="flash-alert">
          <span class="icon icon-16"><svg viewBox="0 0 24 24"><use href="#ic-check"/></svg></span>
          <span>{{ flash.success }}</span>
          <button class="alert-close" onclick="this.closest('.alert').remove()">
            <span class="icon icon-14"><svg viewBox="0 0 24 24"><use href="#ic-x"/></svg></span>
          </button>
        </div>
      {% endif %}
      {% if flash.error %}
        <div class="alert alert-error" id="flash-alert">
          <span class="icon icon-16"><svg viewBox="0 0 24 24"><use href="#ic-alert-circle"/></svg></span>
          <span>{{ flash.error }}</span>
          <button class="alert-close" onclick="this.closest('.alert').remove()">
            <span class="icon icon-14"><svg viewBox="0 0 24 24"><use href="#ic-x"/></svg></span>
          </button>
        </div>
      {% endif %}

      {% block content %}{% endblock %}
    </div>
  </div>

  <div id="toast-root"></div>

  <script src="{{ adminPrefix }}/static/ui.js?v=13"></script>
  <script>
    // ── Global helpers ─────────────────────────────────────────────────────────
    function toast(msg, type)  { UI.Toast.show(msg, type || 'success'); }
    function openModal(id)     { $('#' + id).addClass('open'); }
    function closeModal(id)    { id ? $('#' + id).removeClass('open') : $('.modal-overlay').removeClass('open'); }

    // ── Delete confirmation ─────────────────────────────────────────────────────
    function confirmDelete(url, label) {
      UI.Confirm.show({
        title:   'Delete ' + label,
        message: 'Are you sure you want to delete <strong>' + label + '</strong>? This cannot be undone.',
        confirm: 'Delete',
        danger:  true,
      }).then(function(ok) { if (ok) submitDelete(url); });
    }
    function submitDelete(url) {
      var csrf = $('meta[name="csrf-token"]').attr('content') || '';
      $('<form method="POST">')
        .attr('action', url)
        .append('<input name="_method" value="DELETE">')
        .append('<input name="_csrf" value="' + csrf + '">')
        .appendTo('body')
        .submit();
    }

    // ── M2M dual-list helpers ───────────────────────────────────────────────────
    function m2mMove(fieldName, fromId, toId) {
      $('#m2m-' + fromId + '-' + fieldName + ' option:selected')
        .appendTo('#m2m-' + toId + '-' + fieldName);
    }

    $(function() {
      // ── M2M: select all chosen before submit ──────────────────────────────────
      $('form').on('submit', function() {
        $('[id^="m2m-chosen-"] option').prop('selected', true);
      });

      // ── Flash auto-dismiss ────────────────────────────────────────────────────
      var $flash = $('#flash-alert');
      if ($flash.length) {
        setTimeout(function() {
          $flash.fadeTo(400, 0, function() { $flash.remove(); });
        }, 5000);
      }

      // ── Search placeholder hint ───────────────────────────────────────────────
      $('#global-search-input')
        .on('focus', function() { $(this).attr('placeholder', 'Search everything…'); })
        .on('blur',  function() { $(this).attr('placeholder', 'Search everything… (/)'); });

      // ── Keyboard shortcuts ────────────────────────────────────────────────────
      var prefix    = '{{ adminPrefix }}';
      var resources = [
        {% for r in resources %}
        { slug: '{{ r.slug }}', index: {{ r.index | default('null') }} }{% if not loop.last %},{% endif %}
        {% endfor %}
      ];
      var gPressed = false, gTimer;

      $(document).on('keydown', function(e) {
        var tag = document.activeElement && document.activeElement.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
          if (e.key === 'Escape') $(document.activeElement).blur();
          return;
        }
        if (e.key === '/') {
          e.preventDefault();
          $('#global-search-input').focus();
          return;
        }
        if (e.key === 'n' || e.key === 'N') {
          var $btn = $('a[href*="/create"].btn-primary').first();
          if ($btn.length) { e.preventDefault(); location.href = $btn.attr('href'); }
          return;
        }
        if (e.key === 'Escape') { $('.modal-overlay').removeClass('open'); return; }
        if (e.key === 'g' || e.key === 'G') {
          if (gPressed) return;
          gPressed = true;
          clearTimeout(gTimer);
          gTimer = setTimeout(function() { gPressed = false; }, 800);
          return;
        }
        if (gPressed && (e.key === 'd' || e.key === 'D')) {
          gPressed = false; location.href = prefix + '/'; return;
        }
        if (gPressed && e.key >= '1' && e.key <= '9') {
          gPressed = false;
          var idx = parseInt(e.key);
          var r = $.grep(resources, function(x) { return x.index === idx; })[0];
          if (r) location.href = prefix + '/' + r.slug;
        }
      });
    });
  </script>
  {% block scripts %}{% endblock %}
</body>
</html>
